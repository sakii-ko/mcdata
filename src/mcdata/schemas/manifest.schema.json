{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "lane",
    "profile",
    "mc_version",
    "resources",
    "world",
    "trajectory",
    "action_curriculum",
    "capture",
    "env",
    "git",
    "started_at",
    "ended_at"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "run_id": { "type": "string", "minLength": 1 },
    "lane": { "type": ["string", "null"] },
    "profile": {
      "type": "object",
      "required": ["name", "asset_set", "server_port", "config"],
      "properties": {
        "name": { "type": "string" },
        "loader": { "type": "string" },
        "quality": { "type": ["string", "null"] },
        "asset_set": { "type": "string" },
        "width": { "type": ["integer", "null"] },
        "height": { "type": ["integer", "null"] },
        "server_port": { "type": ["integer", "null"] },
        "config": { "type": "object" }
      },
      "additionalProperties": true
    },
    "mc_version": { "type": "string", "minLength": 1 },
    "resources": {
      "type": "object",
      "required": ["asset_set", "mods", "resourcepacks", "shaderpacks"],
      "properties": {
        "asset_set": { "type": "string" },
        "mods": { "type": "array" },
        "resourcepacks": { "type": "array" },
        "shaderpacks": { "type": "array" }
      },
      "additionalProperties": true
    },
    "world": {
      "type": "object",
      "required": ["seed", "profile", "state"],
      "properties": {
        "seed": {},
        "profile": { "type": ["string", "null"] },
        "state": { "type": "object" }
      },
      "additionalProperties": true
    },
    "trajectory": {
      "type": ["object", "null"],
      "required": ["strategy", "path", "sha256", "event_count"],
      "properties": {
        "strategy": { "type": ["string", "null"] },
        "path": { "type": "string" },
        "source_path": { "type": "string" },
        "sha256": { "type": "string" },
        "event_count": { "type": "integer" },
        "duration_sec": { "type": ["number", "null"] },
        "type": { "type": ["string", "null"] },
        "execution_mode": {
          "enum": ["open_loop_event_replay", "online_position_yaw_feedback"]
        },
        "route_point_count": { "type": "integer", "minimum": 0 },
        "action_source": {"$ref": "#/$defs/actionSource"},
        "native_trace": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/nativeTraceRef"}
          ]
        },
        "curriculum_binding": {"$ref": "#/$defs/nativeCurriculumBinding"},
        "external_rollout_binding": {"$ref": "#/$defs/externalRolloutBinding"}
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "required": ["action_source"],
            "properties": {
              "action_source": {
                "properties": {
                  "id": {
                    "enum": ["human_demo", "learned_visual_policy", "llm_skill_agent"]
                  }
                }
              }
            }
          },
          "then": {"required": ["native_trace", "curriculum_binding"]}
        }
      ]
    },
    "action_curriculum": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/actionCurriculum"}
      ]
    },
    "action_effect": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/actionEffectEvidence"}
      ]
    },
    "capture": {
      "type": "object",
      "required": ["enabled", "settings", "ffmpeg_cmd", "ffprobe"],
      "properties": {
        "enabled": { "type": "boolean" },
        "settings": { "type": "object" },
        "ffmpeg_cmd": { "type": ["array", "null"], "items": { "type": "string" } },
        "ffprobe": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    },
    "env": { "type": "object" },
    "git": {
      "type": "object",
      "required": ["commit", "dirty"],
      "properties": {
        "commit": { "type": ["string", "null"] },
        "dirty": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "started_at": { "type": "string" },
    "ended_at": { "type": ["string", "null"] },
    "error": { "type": ["string", "null"] }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "required": ["action_curriculum"],
        "properties": {
          "action_curriculum": {
            "type": "object",
            "required": ["planned_level"],
            "properties": {"planned_level": {"minimum": 2}}
          }
        }
      },
      "then": {
        "required": ["action_effect"],
        "properties": {"action_effect": {"$ref": "#/$defs/actionEffectEvidence"}}
      }
    }
  ],
  "$defs": {
    "externalRolloutBinding": {
      "type": "object",
      "required": [
        "rollout_schema_version",
        "rollout_sha256",
        "source_minecraft_version",
        "target_minecraft_version",
        "target_client_profile",
        "camera_calibration_sha256",
        "compatibility_status"
      ],
      "properties": {
        "rollout_schema_version": {"const": 1},
        "rollout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_minecraft_version": {"const": "1.16.5"},
        "target_minecraft_version": {"const": "26.2"},
        "target_client_profile": {"type": "string", "minLength": 1},
        "camera_calibration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "compatibility_status": {"const": "target_replay_not_yet_validated"}
      },
      "additionalProperties": false
    },
    "actionSource": {
      "type": "object",
      "required": ["taxonomy_version", "id", "provenance"],
      "properties": {
        "taxonomy_version": {"const": 1},
        "id": {
          "enum": [
            "scripted_astar",
            "feedback_planner",
            "human_demo",
            "learned_visual_policy",
            "llm_skill_agent"
          ]
        },
        "provenance": {"enum": ["declared", "derived_legacy_trajectory"]}
      },
      "additionalProperties": false
    },
    "nativeTraceRef": {
      "type": "object",
      "required": ["schema_version", "sha256", "tick_rate_hz"],
      "properties": {
        "schema_version": {"const": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "tick_rate_hz": {"const": 20}
      },
      "additionalProperties": false
    },
    "nativeCurriculumBinding": {
      "type": "object",
      "required": [
        "status",
        "has_jump_input",
        "has_use_input",
        "has_attack_input"
      ],
      "properties": {
        "status": {
          "enum": ["l1_candidate", "requires_semantic_effect_validation"]
        },
        "has_jump_input": {"type": "boolean"},
        "has_use_input": {"type": "boolean"},
        "has_attack_input": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "actionCounts": {
      "type": "object",
      "required": [
        "navigation_move",
        "navigation_camera",
        "deliberate_jump",
        "deterministic_block_placement",
        "controlled_combat"
      ],
      "properties": {
        "navigation_move": {"type": "integer", "minimum": 0},
        "navigation_camera": {"type": "integer", "minimum": 0},
        "deliberate_jump": {"type": "integer", "minimum": 0},
        "deterministic_block_placement": {"type": "integer", "minimum": 0},
        "controlled_combat": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "controllerRecoveryCounts": {
      "type": "object",
      "required": ["attempts", "jump_taps", "reverse_moves"],
      "properties": {
        "attempts": {"type": "integer", "minimum": 0},
        "jump_taps": {"type": "integer", "minimum": 0},
        "reverse_moves": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "actionEvidence": {
      "type": "object",
      "required": ["kind", "path", "sha256", "size_bytes", "record_count"],
      "properties": {
        "kind": {"enum": ["replay_log", "navigation_log"]},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0},
        "record_count": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "actionEffectEvidence": {
      "type": "object",
      "required": [
        "kind",
        "schema_version",
        "path",
        "sha256",
        "size_bytes",
        "report_id",
        "planned_jump_count",
        "verified_jump_count",
        "accepted"
      ],
      "properties": {
        "kind": {"const": "physical_deliberate_jump"},
        "schema_version": {"const": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 1},
        "report_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "planned_jump_count": {"type": "integer", "minimum": 0},
        "verified_jump_count": {"type": "integer", "minimum": 0},
        "accepted": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "actionCurriculum": {
      "type": "object",
      "required": [
        "taxonomy_version",
        "planned_level",
        "planned_capabilities",
        "observed_semantic_action_counts",
        "observed_level",
        "controller_recovery_counts",
        "bucket",
        "evidence"
      ],
      "properties": {
        "taxonomy_version": {"const": 1},
        "planned_level": {"type": "integer", "minimum": 1, "maximum": 4},
        "planned_capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "navigation",
              "deliberate_jump",
              "deterministic_block_placement",
              "controlled_combat"
            ]
          }
        },
        "observed_semantic_action_counts": {"$ref": "#/$defs/actionCounts"},
        "observed_level": {"type": "integer", "minimum": 0, "maximum": 4},
        "controller_recovery_counts": {"$ref": "#/$defs/controllerRecoveryCounts"},
        "bucket": {"enum": ["l1", "l1_l2", "l1_l2_l3", "l1_l2_l3_l4"]},
        "evidence": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/actionEvidence"}
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"planned_level": {"const": 1}}},
          "then": {
            "properties": {
              "planned_capabilities": {"const": ["navigation"]},
              "bucket": {"const": "l1"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 2}}},
          "then": {
            "properties": {
              "planned_capabilities": {"const": ["navigation", "deliberate_jump"]},
              "bucket": {"const": "l1_l2"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 3}}},
          "then": {
            "properties": {
              "planned_capabilities": {
                "const": ["navigation", "deliberate_jump", "deterministic_block_placement"]
              },
              "bucket": {"const": "l1_l2_l3"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 4}}},
          "then": {
            "properties": {
              "planned_capabilities": {
                "const": [
                  "navigation",
                  "deliberate_jump",
                  "deterministic_block_placement",
                  "controlled_combat"
                ]
              },
              "bucket": {"const": "l1_l2_l3_l4"}
            }
          }
        }
      ]
    }
  }
}
