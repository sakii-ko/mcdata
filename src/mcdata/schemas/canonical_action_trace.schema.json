{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcdata.local/schemas/canonical_action_trace.schema.json",
  "title": "mcdata canonical 20 Hz native action trace",
  "type": "object",
  "required": [
    "schema_version",
    "tick_rate_hz",
    "duration_sec",
    "action_source",
    "producer",
    "source_environment",
    "world",
    "adapter",
    "ticks",
    "trace_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "tick_rate_hz": {"const": 20},
    "duration_sec": {"type": "number", "exclusiveMinimum": 0},
    "trace_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "action_source": {"$ref": "#/$defs/actionSource"},
    "producer": {"$ref": "#/$defs/producer"},
    "source_environment": {"$ref": "#/$defs/sourceEnvironment"},
    "world": {"$ref": "#/$defs/world"},
    "adapter": {"$ref": "#/$defs/adapter"},
    "ticks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/tick"}
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "action_source": {
            "properties": {
              "id": {"enum": ["learned_visual_policy", "llm_skill_agent"]}
            }
          }
        }
      },
      "then": {
        "properties": {
          "producer": {
            "properties": {
              "model_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "actionSource": {
      "type": "object",
      "required": ["taxonomy_version", "id", "provenance"],
      "properties": {
        "taxonomy_version": {"const": 1},
        "id": {
          "enum": [
            "scripted_astar",
            "scripted_skill_agent",
            "feedback_planner",
            "human_demo",
            "learned_visual_policy",
            "llm_skill_agent"
          ]
        },
        "provenance": {"const": "declared"}
      },
      "additionalProperties": false
    },
    "producer": {
      "type": "object",
      "required": ["name", "version", "model_sha256"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "model_sha256": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        }
      },
      "additionalProperties": false
    },
    "sourceEnvironment": {
      "type": "object",
      "required": [
        "name",
        "version",
        "minecraft_version",
        "action_format",
        "action_tick_rate_hz"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "minecraft_version": {"type": "string", "minLength": 1},
        "action_format": {"type": "string", "minLength": 1},
        "action_tick_rate_hz": {"const": 20}
      },
      "additionalProperties": false
    },
    "world": {
      "type": "object",
      "required": ["seed", "snapshot_id", "snapshot_sha256"],
      "properties": {
        "seed": {"type": ["integer", "string"]},
        "snapshot_id": {"type": "string", "minLength": 1},
        "snapshot_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "adapter": {
      "type": "object",
      "required": ["name", "version", "source_format", "parameters"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "source_format": {"type": "string", "minLength": 1},
        "parameters": {"type": "object"}
      },
      "additionalProperties": false
    },
    "tick": {
      "type": "object",
      "required": [
        "tick",
        "source_tick",
        "held_buttons",
        "edge_events",
        "camera_delta_degrees",
        "hotbar",
        "use",
        "attack",
        "inventory"
      ],
      "properties": {
        "tick": {"type": "integer", "minimum": 0},
        "source_tick": {"type": "integer", "minimum": 0},
        "held_buttons": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["forward", "back", "left", "right", "jump", "sneak", "sprint"]
          }
        },
        "edge_events": {
          "type": "array",
          "items": {"$ref": "#/$defs/edgeEvent"}
        },
        "camera_delta_degrees": {
          "type": "object",
          "required": ["pitch", "yaw"],
          "properties": {
            "pitch": {"type": "number"},
            "yaw": {"type": "number"}
          },
          "additionalProperties": false
        },
        "hotbar": {
          "oneOf": [
            {"type": "null"},
            {"type": "integer", "minimum": 1, "maximum": 9}
          ]
        },
        "use": {"type": "boolean"},
        "attack": {"type": "boolean"},
        "inventory": {"type": "boolean"},
        "semantic_annotations": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "edgeEvent": {
      "oneOf": [
        {
          "type": "object",
          "required": ["control", "edge"],
          "properties": {
            "control": {
              "enum": [
                "forward",
                "back",
                "left",
                "right",
                "jump",
                "sneak",
                "sprint",
                "attack",
                "use"
              ]
            },
            "edge": {"enum": ["press", "release"]}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["control", "edge"],
          "properties": {
            "control": {"const": "inventory"},
            "edge": {"const": "press"}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["control", "edge", "slot"],
          "properties": {
            "control": {"const": "hotbar"},
            "edge": {"const": "select"},
            "slot": {"type": "integer", "minimum": 1, "maximum": 9}
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
