{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcdata.local/schemas/edit_pair_manifest.schema.json",
  "title": "mcdata edit-pair manifest",
  "type": "object",
  "required": ["schema_version", "pairs"],
  "properties": {
    "schema_version": {"const": 1},
    "pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["prompt", "source_episode", "target_episode", "edit_axis"],
        "properties": {
          "prompt": {"type": "string", "minLength": 1},
          "source_episode": {"type": "string", "minLength": 1},
          "target_episode": {"type": "string", "minLength": 1},
          "edit_axis": {
            "enum": [
              "material_style",
              "shader_quality",
              "time_of_day",
              "weather",
              "snow_weather"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
