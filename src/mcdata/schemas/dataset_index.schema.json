{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcdata.local/schemas/dataset_index.schema.json",
  "title": "mcdata dataset index",
  "type": "object",
  "required": [
    "schema_version",
    "generator",
    "dataset_id",
    "status",
    "primary_cohort_id",
    "invariants",
    "cohorts",
    "episodes",
    "action_buckets",
    "action_sources",
    "pair_manifest",
    "pairs",
    "comparisons",
    "manual_review",
    "checksum_manifest"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "generator": {
      "type": "object",
      "required": ["name", "git_commit"],
      "properties": {
        "name": {"const": "mcdata.dataset-index"},
        "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "dataset_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "status": {"enum": ["automated_pass", "accepted"]},
    "primary_cohort_id": {"type": "string", "pattern": "^cohort-[0-9a-f]{16}$"},
    "checksum_manifest": {"const": "SHA256SUMS"},
    "invariants": {
      "type": "object",
      "required": [
        "mc_version",
        "git_commit",
        "trajectory_sha256",
        "trajectory_event_count",
        "trajectory_execution_mode",
        "trajectory_duration_sec",
        "world_seed",
        "world_profile",
        "resourcepack_target",
        "capture"
      ],
      "properties": {
        "mc_version": {"type": "string"},
        "git_commit": {"type": "string", "minLength": 1},
        "trajectory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "trajectory_event_count": {"type": "integer", "minimum": 0},
        "trajectory_execution_mode": {
          "enum": ["open_loop_event_replay", "online_position_yaw_feedback"]
        },
        "trajectory_duration_sec": {"type": "number", "exclusiveMinimum": 0},
        "world_seed": {"type": ["integer", "string"]},
        "world_profile": {"type": "string"},
        "resourcepack_target": {"$ref": "#/$defs/resourcepackTarget"},
        "capture": {"$ref": "#/$defs/captureFacts"}
      }
    },
    "cohorts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "cohort_id",
          "role",
          "world_state_sha256",
          "world_state",
          "episode_ids",
          "profile_names"
        ],
        "properties": {
          "cohort_id": {"type": "string", "pattern": "^cohort-[0-9a-f]{16}$"},
          "role": {
            "enum": [
              "strict_rendering_matrix",
              "policy_aligned_rendering_matrix",
              "world_state_variant"
            ]
          },
          "world_state_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "world_state": {"type": "object"},
          "episode_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "profile_names": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    },
    "episodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "episode_id",
          "run_id",
          "cohort_id",
          "profile_name",
          "asset_set",
          "run_dir",
          "manifest",
          "video",
          "trajectory",
          "action_curriculum",
          "action_curriculum_source",
          "action_source",
          "native_trace_sha256",
          "action_effect",
          "positions",
          "qa",
          "client_log",
          "shader_runtime",
          "resourcepack_runtime_status",
          "mods",
          "resourcepacks",
          "shaderpacks",
          "resourcepack_resolution",
          "accepted"
        ],
        "properties": {
          "episode_id": {"type": "string"},
          "run_id": {"type": "string"},
          "cohort_id": {"type": "string"},
          "profile_name": {"type": "string"},
          "asset_set": {"type": "string"},
          "run_dir": {"type": "string"},
          "manifest": {
            "allOf": [
              {"$ref": "#/$defs/artifact"},
              {
                "type": "object",
                "required": ["schema_version"],
                "properties": {"schema_version": {"enum": [2, 3]}}
              }
            ]
          },
          "video": {
            "allOf": [
              {"$ref": "#/$defs/artifact"},
              {"$ref": "#/$defs/captureFacts"}
            ]
          },
          "trajectory": {
            "allOf": [
              {"$ref": "#/$defs/artifact"},
              {
                "type": "object",
                "required": [
                  "event_count",
                  "duration_sec",
                  "execution_mode",
                  "route_point_count"
                ],
                "properties": {
                  "event_count": {"type": "integer", "minimum": 0},
                  "duration_sec": {"type": "number", "exclusiveMinimum": 0},
                  "execution_mode": {
                    "enum": ["open_loop_event_replay", "online_position_yaw_feedback"]
                  },
                  "route_point_count": {"type": "integer", "minimum": 0}
                }
              }
            ]
          },
          "action_curriculum": {"$ref": "#/$defs/acceptedActionCurriculum"},
          "action_curriculum_source": {
            "enum": ["manifest", "derived_legacy_replay"]
          },
          "action_source": {"$ref": "#/$defs/actionSource"},
          "native_trace_sha256": {
            "oneOf": [
              {"type": "null"},
              {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            ]
          },
          "action_effect": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/acceptedActionEffect"}
            ]
          },
          "positions": {"$ref": "#/$defs/artifact"},
          "navigation": {"$ref": "#/$defs/artifact"},
          "qa": {
            "allOf": [
              {"$ref": "#/$defs/artifact"},
              {
                "type": "object",
                "required": [
                  "passed",
                  "warnings",
                  "route_max_deviation_blocks",
                  "route_mean_deviation_blocks"
                ],
                "properties": {
                  "passed": {"const": true},
                  "warnings": {"type": "array", "maxItems": 0},
                  "route_max_deviation_blocks": {"type": "number", "minimum": 0},
                  "route_mean_deviation_blocks": {"type": "number", "minimum": 0}
                }
              }
            ]
          },
          "client_log": {"$ref": "#/$defs/artifact"},
          "shader_runtime": {
            "type": "object",
            "required": ["status", "expected_shaderpack", "observed_shaderpacks", "evidence_line"],
            "properties": {
              "status": {"const": "pass"},
              "expected_shaderpack": {"type": ["string", "null"]},
              "observed_shaderpacks": {"type": "array", "items": {"type": "string"}},
              "evidence_line": {"type": "string", "minLength": 1}
            }
          },
          "resourcepack_runtime_status": {"const": "pass"},
          "mods": {"type": "array", "items": {"$ref": "#/$defs/resource"}},
          "resourcepacks": {"type": "array", "items": {"$ref": "#/$defs/resource"}},
          "shaderpacks": {"type": "array", "items": {"$ref": "#/$defs/resource"}},
          "resourcepack_resolution": {"$ref": "#/$defs/resourcepackResolution"},
          "accepted": {"const": true}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "action_curriculum": {
                  "properties": {"planned_level": {"const": 1}}
                }
              }
            },
            "then": {"properties": {"action_effect": {"type": "null"}}},
            "else": {
              "properties": {
                "action_effect": {"$ref": "#/$defs/acceptedActionEffect"}
              }
            }
          },
          {
            "if": {
              "properties": {
                "action_source": {
                  "properties": {
                    "id": {
                      "enum": ["human_demo", "learned_visual_policy", "llm_skill_agent"]
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "native_trace_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              }
            }
          }
        ]
      }
    },
    "action_buckets": {
      "type": "object",
      "required": ["taxonomy_version", "l1", "l1_l2", "l1_l2_l3", "l1_l2_l3_l4"],
      "properties": {
        "taxonomy_version": {"const": 1},
        "l1": {"$ref": "#/$defs/actionBucket"},
        "l1_l2": {"$ref": "#/$defs/actionBucket"},
        "l1_l2_l3": {"$ref": "#/$defs/actionBucket"},
        "l1_l2_l3_l4": {"$ref": "#/$defs/actionBucket"}
      },
      "additionalProperties": false
    },
    "action_sources": {
      "type": "object",
      "required": [
        "taxonomy_version",
        "scripted_astar",
        "feedback_planner",
        "human_demo",
        "learned_visual_policy",
        "llm_skill_agent"
      ],
      "properties": {
        "taxonomy_version": {"const": 1},
        "scripted_astar": {"$ref": "#/$defs/actionSourceBucket"},
        "feedback_planner": {"$ref": "#/$defs/actionSourceBucket"},
        "human_demo": {"$ref": "#/$defs/actionSourceBucket"},
        "learned_visual_policy": {"$ref": "#/$defs/actionSourceBucket"},
        "llm_skill_agent": {"$ref": "#/$defs/actionSourceBucket"}
      },
      "additionalProperties": false
    },
    "pair_manifest": {
      "allOf": [
        {"$ref": "#/$defs/artifact"},
        {
          "type": "object",
          "required": ["schema_version"],
          "properties": {"schema_version": {"const": 1}}
        }
      ]
    },
    "pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "pair_id",
          "prompt",
          "source_episode",
          "target_episode",
          "edit_axis",
          "invariants",
          "axis_values"
        ],
        "properties": {
          "pair_id": {"type": "string", "pattern": "^pair-[0-9a-f]{16}$"},
          "prompt": {"type": "string", "minLength": 1},
          "source_episode": {"type": "string", "minLength": 1},
          "target_episode": {"type": "string", "minLength": 1},
          "edit_axis": {
            "enum": [
              "material_style",
              "shader_quality",
              "time_of_day",
              "weather",
              "snow_weather"
            ]
          },
          "invariants": {
            "type": "object",
            "required": [
              "mc_version",
              "git_commit",
              "world_seed",
              "world_profile",
              "scene_sha256",
              "spawn_sha256",
              "trajectory_sha256",
              "trajectory_contract_sha256",
              "action_source",
              "native_trace_sha256",
              "capture_spec_sha256",
              "static_state_sha256",
              "qa_passed"
            ],
            "properties": {
              "mc_version": {"type": "string", "minLength": 1},
              "git_commit": {"type": "string", "minLength": 1},
              "world_seed": {"type": ["integer", "string"]},
              "world_profile": {"type": "string", "minLength": 1},
              "scene_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "spawn_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "trajectory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "trajectory_contract_sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "action_source": {
                "enum": [
                  "scripted_astar",
                  "feedback_planner",
                  "human_demo",
                  "learned_visual_policy",
                  "llm_skill_agent"
                ]
              },
              "native_trace_sha256": {
                "oneOf": [
                  {"type": "null"},
                  {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                ]
              },
              "capture_spec_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "static_state_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "qa_passed": {"const": true}
            },
            "additionalProperties": false
          },
          "axis_values": {
            "type": "object",
            "required": ["source", "target", "source_sha256", "target_sha256"],
            "properties": {
              "source": {},
              "target": {},
              "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "target_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "comparisons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {"$ref": "#/$defs/artifact"},
          {
            "type": "object",
            "required": ["role", "member_episode_ids", "position_alignment"],
            "properties": {
              "role": {"enum": ["cohort_gate", "all_dataset_diagnostic"]},
              "member_episode_ids": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              },
              "position_alignment": {
                "type": "object",
                "required": [
                  "passed",
                  "threshold_blocks",
                  "max_distance_blocks",
                  "mean_distance_blocks"
                ],
                "properties": {
                  "passed": {"const": true},
                  "threshold_blocks": {"type": "number", "exclusiveMinimum": 0, "maximum": 2},
                  "max_distance_blocks": {"type": "number", "minimum": 0},
                  "mean_distance_blocks": {"type": "number", "minimum": 0}
                }
              }
            }
          }
        ]
      }
    },
    "manual_review": {
      "oneOf": [
        {"type": "null"},
        {
          "allOf": [
            {"$ref": "#/$defs/artifact"},
            {
              "type": "object",
              "required": ["status", "reviewed_profiles", "evidence", "notes"],
              "properties": {
                "status": {"const": "pass"},
                "reviewed_profiles": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "string"}
                },
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"$ref": "#/$defs/artifact"}
                },
                "notes": {"type": "array", "items": {"type": "string"}}
              }
            }
          ]
        }
      ]
    }
  },
  "$defs": {
    "actionSource": {
      "type": "object",
      "required": ["taxonomy_version", "id", "provenance"],
      "properties": {
        "taxonomy_version": {"const": 1},
        "id": {
          "enum": [
            "scripted_astar",
            "feedback_planner",
            "human_demo",
            "learned_visual_policy",
            "llm_skill_agent"
          ]
        },
        "provenance": {"enum": ["declared", "derived_legacy_trajectory"]}
      },
      "additionalProperties": false
    },
    "actionSourceBucket": {
      "type": "object",
      "required": ["episode_count", "episode_ids", "pair_count", "pair_ids"],
      "properties": {
        "episode_count": {"type": "integer", "minimum": 0},
        "episode_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "pair_count": {"type": "integer", "minimum": 0},
        "pair_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "actionBucket": {
      "type": "object",
      "required": ["episode_count", "episode_ids"],
      "properties": {
        "episode_count": {"type": "integer", "minimum": 0},
        "episode_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "actionCounts": {
      "type": "object",
      "required": [
        "navigation_move",
        "navigation_camera",
        "deliberate_jump",
        "deterministic_block_placement",
        "controlled_combat"
      ],
      "properties": {
        "navigation_move": {"type": "integer", "minimum": 0},
        "navigation_camera": {"type": "integer", "minimum": 0},
        "deliberate_jump": {"type": "integer", "minimum": 0},
        "deterministic_block_placement": {"type": "integer", "minimum": 0},
        "controlled_combat": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "controllerRecoveryCounts": {
      "type": "object",
      "required": ["attempts", "jump_taps", "reverse_moves"],
      "properties": {
        "attempts": {"type": "integer", "minimum": 0},
        "jump_taps": {"type": "integer", "minimum": 0},
        "reverse_moves": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "acceptedActionCurriculum": {
      "type": "object",
      "required": [
        "taxonomy_version",
        "planned_level",
        "planned_capabilities",
        "observed_semantic_action_counts",
        "observed_level",
        "controller_recovery_counts",
        "bucket",
        "evidence"
      ],
      "properties": {
        "taxonomy_version": {"const": 1},
        "planned_level": {"type": "integer", "minimum": 1, "maximum": 4},
        "planned_capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "navigation",
              "deliberate_jump",
              "deterministic_block_placement",
              "controlled_combat"
            ]
          }
        },
        "observed_semantic_action_counts": {"$ref": "#/$defs/actionCounts"},
        "observed_level": {"type": "integer", "minimum": 1, "maximum": 4},
        "controller_recovery_counts": {"$ref": "#/$defs/controllerRecoveryCounts"},
        "bucket": {"enum": ["l1", "l1_l2", "l1_l2_l3", "l1_l2_l3_l4"]},
        "evidence": {
          "allOf": [
            {"$ref": "#/$defs/artifact"},
            {
              "type": "object",
              "required": ["kind", "record_count"],
              "properties": {
                "kind": {"enum": ["replay_log", "navigation_log"]},
                "record_count": {"type": "integer", "minimum": 1}
              }
            }
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"planned_level": {"const": 1}}},
          "then": {
            "properties": {
              "planned_capabilities": {"const": ["navigation"]},
              "bucket": {"const": "l1"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 2}}},
          "then": {
            "properties": {
              "planned_capabilities": {"const": ["navigation", "deliberate_jump"]},
              "bucket": {"const": "l1_l2"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 3}}},
          "then": {
            "properties": {
              "planned_capabilities": {
                "const": ["navigation", "deliberate_jump", "deterministic_block_placement"]
              },
              "bucket": {"const": "l1_l2_l3"}
            }
          }
        },
        {
          "if": {"properties": {"planned_level": {"const": 4}}},
          "then": {
            "properties": {
              "planned_capabilities": {
                "const": [
                  "navigation",
                  "deliberate_jump",
                  "deterministic_block_placement",
                  "controlled_combat"
                ]
              },
              "bucket": {"const": "l1_l2_l3_l4"}
            }
          }
        }
      ]
    },
    "acceptedActionEffect": {
      "allOf": [
        {"$ref": "#/$defs/artifact"},
        {
          "type": "object",
          "required": [
            "kind",
            "schema_version",
            "report_id",
            "planned_jump_count",
            "verified_jump_count",
            "accepted"
          ],
          "properties": {
            "kind": {"const": "physical_deliberate_jump"},
            "schema_version": {"const": 1},
            "report_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "planned_jump_count": {"const": 4},
            "verified_jump_count": {"const": 4},
            "accepted": {"const": true}
          }
        }
      ]
    },
    "artifact": {
      "type": "object",
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "captureFacts": {
      "type": "object",
      "required": ["width", "height", "fps", "duration_sec", "frame_count"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "duration_sec": {"type": "number", "exclusiveMinimum": 0},
        "frame_count": {"type": "integer", "minimum": 1}
      }
    },
    "resource": {
      "type": "object",
      "required": ["filename", "sha256", "size_bytes"],
      "properties": {
        "filename": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "resourcepackTarget": {
      "type": "object",
      "required": ["resource_major", "resource_minor", "source_jar_sha256"],
      "properties": {
        "resource_major": {"type": "integer", "minimum": 0},
        "resource_minor": {"type": "integer", "minimum": 0},
        "source_jar_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "resourcepackResolution": {
      "type": "object",
      "required": ["schema_version", "game_version", "normalizer_version", "target", "packs"],
      "properties": {
        "schema_version": {"const": 1},
        "game_version": {"type": "string", "minLength": 1},
        "normalizer_version": {"type": "string", "minLength": 1},
        "target": {"$ref": "#/$defs/resourcepackTarget"},
        "packs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "filename",
              "project",
              "version",
              "download_url",
              "expected_size",
              "normalized",
              "source_sha256",
              "source_sha512",
              "upstream_sha512",
              "effective_sha256",
              "before",
              "after"
            ],
            "properties": {
              "filename": {"type": "string", "minLength": 1},
              "project": {"type": "string", "minLength": 1},
              "version": {"type": "string", "minLength": 1},
              "download_url": {"type": "string", "pattern": "^https://"},
              "expected_size": {"type": "integer", "minimum": 1},
              "normalized": {"type": "boolean"},
              "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "source_sha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
              "upstream_sha512": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
              "effective_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "before": {"type": "object"},
              "after": {"type": "object"}
            }
          }
        }
      }
    }
  }
}
